# Horizon — variables d'environnement (copier vers .env à la racine du dépôt)

APP_ENV=development
APP_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_openssl_rand_hex_32
APP_DEBUG=true

JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql+psycopg2://horizon_user:horizon_pass@localhost:5432/horizon_db
REDIS_URL=redis://localhost:6379/0

EMAIL_MODE=smtp
# Paramètres SMTP (exemple avec Gmail, nécessite un mot de passe d'application)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application_google
SMTP_TLS=true
EMAIL_FROM=no-reply@horizon.enspy.cm
EMAIL_FROM_NAME=Horizon ENSPY

BCRYPT_ROUNDS=12
ENFORCE_HTTPS=false
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
ADMIN_ALERT_ATTEMPTS=10

INACTIVITY_SUSPENSION_DAYS=90
INACTIVITY_WARNING_DAYS=83
DELETION_AFTER_SUSPENSION_DAYS=30

VM_EXPIRY_WARNING_MINUTES=30
VM_AUTO_DELETE_AFTER_STOPPED_DAYS=7
SHARED_SPACE_RETENTION_HOURS=24
SHARED_SPACE_PURGE_WARNING_HOURS=2

VM_INACTIVITY_ALERT_HOURS=2
AUDIT_LOG_RETENTION_DAYS=90
MONITORING_INTERVAL_SECONDS=60

# Proxmox — laisser PROXMOX_ENABLED=false pour le dev sans cluster
PROXMOX_ENABLED=true
PROXMOX_HOST=192.168.122.107
PROXMOX_USER=root
PROXMOX_TOKEN_ID=horizon
PROXMOX_TOKEN_SECRET=your_token_secret
PROXMOX_VERIFY_SSL=false
PROXMOX_DEFAULT_NODE=pve1
PROXMOX_NET0_TEMPLATE=virtio,bridge=vmbr0
